NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://monitor:changeme@localhost:5432/monitor?schema=public

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=sites

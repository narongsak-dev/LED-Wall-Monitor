VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# ตั้งเป็น true เพื่อใช้ mock telemetry data (สำหรับช่วงยังไม่มี hardware)
VITE_USE_MOCK=true

# ตั้งเป็น true เพื่อใช้ mock auth + mock sites (สำหรับช่วงยังไม่ได้รัน backend)
# ในโหมดนี้: ใช้ user/pass ใดๆ ก็เข้าได้ และมีตัวอย่างไซต์ 3 ไซต์
VITE_USE_MOCK_AUTH=true

# Copy to `.env` and fill in real values before running docker compose.
# Anything marked CHANGE_ME is REQUIRED — the compose file will refuse to
# start without them.

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=monitor
POSTGRES_DB=monitor
POSTGRES_PASSWORD=CHANGE_ME_pg_strong_password

# ─── MQTT broker (EMQX) ───────────────────────────────────────────
# Boards connect to mqtt://<server-ip>:1883 (or mqtts://...:8883 with TLS).
# Leave MQTT_USERNAME / MQTT_PASSWORD blank for anonymous (dev only); for
# production set them and configure matching credentials on each board.
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_emqx_dashboard
EMQX_MQTT_PORT=1883
EMQX_MQTT_TLS_PORT=8883
EMQX_DASHBOARD_PORT=18083

MQTT_URL=mqtt://emqx:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=sites

# ─── Backend (NestJS) ─────────────────────────────────────────────
# Use `openssl rand -hex 32` to generate strong secrets.
JWT_ACCESS_SECRET=CHANGE_ME_64_hex_chars
JWT_REFRESH_SECRET=CHANGE_ME_64_hex_chars_different
CORS_ORIGIN=https://monitor.dragontrusts.com

# Backend container port published on the host. The host nginx proxies here.
# Bound to 127.0.0.1 by default; edit docker-compose.prod.yml if you want LAN.
BACKEND_HOST_PORT=3001

# ─── Frontend (static SPA + tiny nginx) ───────────────────────────
# Bake the API base into the bundle at build time. "/" is correct when the
# host nginx serves frontend and backend on the same origin.
VITE_API_BASE=/
FRONTEND_HOST_PORT=8081
